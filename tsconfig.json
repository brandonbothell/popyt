{
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "types": [ "node" ],
    "module": "Node16",
    "target": "es2022",
    "outDir": "out",
    "declarationDir": "typings",
    "declaration": true,
    "removeComments": false,
    "sourceMap": true,
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "allowJs": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "docusaurus/**/*.ts",
    "docusaurus/**/*.tsx"
  ],
  "files": [
    "eslint.config.mts"
  ],
  "exclude": [
    ".yarn",
    "node_modules",
    "out",
    "typings",
  ]
}
