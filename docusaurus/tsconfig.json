{
  // Compiles docusaurus.config.ts, sidebars.ts, and babel.config.ts
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "outDir": ".",
    "noEmit": false,
    "allowJs": false,
    "types": [
      "@docusaurus/module-type-aliases",
      "@docusaurus/theme-classic"
    ]
  },
  "files": [
    "./sidebars.ts",
    "./docusaurus.config.ts",
    "./babel.config.ts"
  ]
}
