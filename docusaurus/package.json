{
  "name": "docusaurus",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "yarn build:config && docusaurus",
    "start": "yarn build:config && docusaurus start",
    "build": "yarn build:config && docusaurus build",
    "swizzle": "yarn build:config && docusaurus swizzle",
    "deploy": "yarn build:config && docusaurus deploy",
    "clear": "yarn build:config && docusaurus clear",
    "serve": "yarn build:config && docusaurus serve",
    "write-translations": "yarn build:config && docusaurus write-translations",
    "write-heading-ids": "yarn build:config && docusaurus write-heading-ids",
    "build:config": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/plugin-content-docs": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "3.1.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/theme-classic": "3.10.0",
    "@docusaurus/theme-common": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "docusaurus-plugin-typedoc": "1.4.2",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  },
  "packageManager": "yarn@4.14.1"
}
