{
  "name": "popyt",
  "version": "8.0.0",
  "description": "A very easy to use promise-based Youtube Data v3 API.",
  "homepage": "https://brandonbothell.github.io/popyt/",
  "main": "out/index.js",
  "types": "typings/index.d.ts",
  "scripts": {
    "test": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/*.spec.ts\" --timeout 30000",
    "test:oauth": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/oauth/*.spec.ts\" --timeout 30000",
    "test:oauth:captions": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/oauth/captions.spec.ts\" --timeout 30000",
    "test:oauth:channels": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/oauth/channels.spec.ts\" --timeout 30000",
    "test:http": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/request.spec.ts\" --timeout 30000",
    "test:comments": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/comments.spec.ts\" --timeout 30000",
    "test:youtube": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/youtube.spec.ts\" --timeout 30000",
    "test:playlist-items": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/playlist-items.spec.ts\" --timeout 30000",
    "test:subscriptions": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/subscription.spec.ts\" --timeout 30000",
    "test:all": "yarn mocha --exit --require ts-node/register/transpile-only --require source-map-support/register --recursive \"./test/**/*.spec.ts\" --timeout 30000",
    "coverage": "tsc && cross-env NODE_ENV=test nyc --reporter=json yarn test",
    "coverage:all": "tsc && cross-env NODE_ENV=test nyc --reporter=json yarn test:all",
    "coverage:allhtml": "tsc && cross-env NODE_ENV=test nyc --reporter=lcov yarn test:all",
    "coverage:html": "tsc && cross-env NODE_ENV=test nyc --reporter=lcov yarn test",
    "coverage:text": "tsc && cross-env NODE_ENV=test nyc --reporter=text yarn test",
    "docs:build:config": "yarn workspace docusaurus build:config",
    "docs:build": "yarn workspace docusaurus build",
    "docs:publish": "yarn workspace docusaurus deploy",
    "docs:serve": "yarn workspace docusaurus serve",
    "docs:test": "yarn workspace docusaurus start",
    "lint": "eslint .",
    "build": "tsc --build --clean && tsc"
  },
  "nyc": {
    "include": "src"
  },
  "workspaces": [
    "docusaurus"
  ],
  "author": {
    "name": "Brandon Bothell",
    "email": "bothellbrandon@gmail.com"
  },
  "license": "Unlicense",
  "keywords": [
    "youtube",
    "youtube search",
    "youtube api",
    "youtube videos",
    "youtube channels",
    "promise",
    "promise based",
    "no dependencies",
    "caching"
  ],
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@googleapis/youtube": "31.0.0",
    "@istanbuljs/nyc-config-typescript": "1.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "5.2.3",
    "@types/gulp": "4.0.18",
    "@types/gulp-sourcemaps": "0.0.38",
    "@types/merge2": "1.4.4",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "chai": "6.2.2",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "eslint": "10.2.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "^17.5.0",
    "mocha": "11.7.5",
    "nyc": "18.0.0",
    "source-map-support": "0.5.21",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "undici-types": "8.1.0"
  },
  "resolutions": {
    "node-preload": "0.2.0",
    "webpack": "5.105.0"
  },
  "engines": {
    "node": ">=18.0 <24.0"
  },
  "repository": {
    "url": "https://github.com/brandonbothell/popyt.git"
  },
  "packageManager": "yarn@4.10.3"
}
