{
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "types": [ "node" ],
    "module": "Node16",
    "target": "es2022",
    "outDir": "out",
    "declarationDir": "typings",
    "declaration": true,
    "removeComments": false,
    "sourceMap": true,
    "rootDir": "src",
    "strict": false,
    "esModuleInterop": true,
    "allowJs": true
  },
  "include": [
    "src/**/*.ts",
  ],
  "files": null,
  "exclude": [
    ".yarn",
    "node_modules",
    "out",
    "typings",
    "docusaurus"
  ]
}
